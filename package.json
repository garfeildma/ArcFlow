{
  "name": "arcflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts",
    "contracts:deploy": "forge script script/Deploy.s.sol --root contracts --rpc-url $ARC_RPC_URL --broadcast"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.25.0",
    "@supabase/supabase-js": "^2.105.4",
    "hono": "^4.12.18",
    "jose": "^6.1.3",
    "lucide-react": "^0.554.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "viem": "^2.48.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "vite": "5.4.21",
    "wrangler": "3.114.16"
  }
}
